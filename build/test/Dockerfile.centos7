# =============================================================================
# Test environment: validate the assembled octg tarball on CentOS 7
# =============================================================================
FROM centos:7

# ── CentOS 7 is EOL — switch to vault mirrors ────────────────────────────────
RUN sed -i 's|^mirrorlist=|#mirrorlist=|g' /etc/yum.repos.d/CentOS-*.repo \
    && sed -i 's|^#baseurl=http://mirror.centos.org|baseurl=http://vault.centos.org|g' /etc/yum.repos.d/CentOS-*.repo \
    && yum install -y git curl \
    && yum clean all

# ── Copy the assembled tarball into the image ────────────────────────────────
COPY staging/octg/ /opt/octg/

# ── Copy test script ─────────────────────────────────────────────────────────
COPY build/test/test-env.sh /opt/test-env.sh

# Ensure all binaries + runtime libs are executable.
# CI artifact pipeline can drop the execute bit on lib/opencode and on the
# musl runtime (ld-musl-x86_64.so.1). The kernel requires +x on the ELF
# interpreter — without it, execve returns EACCES ("Permission denied").
RUN chmod +x /opt/test-env.sh /opt/octg/setup.sh /opt/octg/octg \
             /opt/octg/bin/opencode /opt/octg/bin/opencode.bin \
             /opt/octg/bin/opencode-telegram \
             /opt/octg/lib/opencode \
             /opt/octg/lib/ld-musl-x86_64.so.1 \
             /opt/octg/node/bin/node

# ── Pre-create musl loader symlink + .path file ──────────────────────────────
# The bin/opencode wrapper creates these at runtime, but pre-creating them
# isolates the test from wrapper logic — we're validating the binary works.
RUN mkdir -p /tmp/.octg-ld \
    && ln -sf /opt/octg/lib/ld-musl-x86_64.so.1 /tmp/.octg-ld/ld-musl-x86_64.so.1 \
    && mkdir -p /tmp/etc \
    && printf '/opt/octg/lib' > /tmp/etc/ld-musl-x86_64.path

CMD ["/opt/test-env.sh"]
